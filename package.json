{
  "name": "mocking-bird-ai",
  "version": "2.1.14",
  "description": "Cross-platform AI interview assistant",
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/bjosh12/mocking-bird-ai.git"
  },
  "build": {
    "appId": "com.mockingbird.app",
    "productName": "Mocking-Bird-AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bjosh12",
        "repo": "mocking-bird-ai",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null,
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mocking Bird AI",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "public/icon.png",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"if(process.platform==='win32'){require('child_process').execSync('node scripts/create-icon.js',{stdio:'inherit'})}\" && node scripts/prepare-wincsodesign.js",
    "build": "tsc && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:dir": "tsc && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "serve": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.104.1",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "6.8.3",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.379.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "electron": "^30.0.8",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
